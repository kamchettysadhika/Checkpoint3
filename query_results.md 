## Query (M) — Customers who purchased books by the most profitable author(s)

```sql
WITH most_profitable AS (
    SELECT a.author_id,
           SUM(oi.quantity * oi.unit_price * (1 - oi.discount_applied)) AS revenue
    FROM AUTHOR a
    JOIN BOOK_AUTHOR ba ON a.author_id = ba.author_id
    JOIN ORDER_ITEM oi ON ba.book_id = oi.book_id
    GROUP BY a.author_id
    HAVING revenue = (
        SELECT MAX(sub.rev) FROM (
            SELECT SUM(oi2.quantity * oi2.unit_price * (1 - oi2.discount_applied)) AS rev
            FROM BOOK_AUTHOR ba2
            JOIN ORDER_ITEM oi2 ON ba2.book_id = oi2.book_id
            GROUP BY ba2.author_id
        ) sub
    )
)
SELECT DISTINCT c.first_name || ' ' || c.last_name AS customer
FROM CUSTOMER c
JOIN ORDERS o ON c.customer_id = o.customer_id
JOIN ORDER_ITEM oi ON o.order_id = oi.order_id
JOIN BOOK_AUTHOR ba ON oi.book_id = ba.book_id
JOIN most_profitable mp ON ba.author_id = mp.author_id;
```

