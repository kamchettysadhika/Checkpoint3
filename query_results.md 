## Query (N) — Authors of books purchased by high-spender customers

```sql
WITH high_spenders AS (
    SELECT o.customer_id
    FROM ORDERS o
    JOIN ORDER_ITEM oi ON o.order_id = oi.order_id
    GROUP BY o.customer_id
    HAVING SUM(oi.quantity * oi.unit_price * (1 - oi.discount_applied)) > (
        SELECT AVG(sub.total) FROM (
            SELECT SUM(oi2.quantity * oi2.unit_price * (1 - oi2.discount_applied)) AS total
            FROM ORDERS o2
            JOIN ORDER_ITEM oi2 ON o2.order_id = oi2.order_id
            GROUP BY o2.customer_id
        ) sub
    )
)
SELECT DISTINCT a.first_name || ' ' || a.last_name AS author
FROM AUTHOR a
JOIN BOOK_AUTHOR ba ON a.author_id = ba.author_id
JOIN ORDER_ITEM oi ON ba.book_id = oi.book_id
JOIN ORDERS o ON oi.order_id = o.order_id
JOIN high_spenders hs ON o.customer_id = hs.customer_id
ORDER BY author;
```

